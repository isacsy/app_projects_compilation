rules_version = '2';

// Every user's data lives under /users/{their uid}. This scopes all reads
// and writes -- the top-level user doc (cash balance) and every
// subcollection under it (watchlist, holdings) -- to that user only.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
